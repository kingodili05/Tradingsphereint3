# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role key — used server-side only (NEVER expose to the browser)
# Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used in email links. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://tradingsphereint.online

# ─── Resend (free email service — resend.com) ─────────────────────────────────
# 1. Sign up free at https://resend.com
# 2. Go to API Keys → Create API Key
# 3. Paste it below
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "From" address in outgoing emails.
# IMPORTANT: must be from a domain you verified in Resend.
# While testing you can use: onboarding@resend.dev  (Resend's sandbox address)
# For production, add your domain at resend.com/domains and use e.g.:
#   noreply@tradingsphereint.online
RESEND_FROM=onboarding@resend.dev

# Where contact-form notifications are delivered (your admin inbox)
ADMIN_EMAIL=support@tradingsphereint.online
